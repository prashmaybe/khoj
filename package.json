{
  "name": "khoj",
  "version": "0.1.0",
  "description": "A modern cross-platform browser built with React Native and Electron",
  "author": {
    "name": "Prashant Kapoor",
    "email": "prashmaybe@gmail.com"
  },
  "productName": "Khoj",
  "main": "main.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "electron": "electron ./electron-runtime.js",
    "electron-dev": "electron ./electron-runtime.js",
    "desktop": "electron ./electron-runtime.js",
    "web": "webpack serve --mode development --open",
    "build:webpack": "webpack --mode production",
    "build:main": "tsc -p tsconfig.electron.json",
    "build-electron": "npm run build:webpack && npm run build:main && electron-builder",
    "test": "jest",
    "build": "npm run build-desktop",
    "build-desktop": "npm run build-windows && npm run build-macos && npm run build-linux",
    "build-windows": "npm run build:webpack && npm run build:main && electron-builder --win",
    "build-macos": "npm run build:webpack && npm run build:main && electron-builder --mac",
    "build-linux": "npm run build:webpack && npm run build:main && electron-builder --linux",
    "build-mobile": "npm run build-android && npm run build-ios",
    "build-android": "cd android && ./gradlew assembleRelease",
    "build-ios": "cd ios && xcodebuild -workspace Khoj.xcworkspace -scheme Khoj -configuration Release -destination generic/platform=iOS -archivePath build/Khoj.xcarchive archive",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist": "npm run build:webpack && npm run build:main && electron-builder --publish=never",
    "dist-all": "npm run build:webpack && npm run build:main && electron-builder -mwl --publish=never",
    "clean": "rimraf dist out build release public/bundle.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prashmaybe/khoj.git"
  },
  "keywords": [
    "browser",
    "electron",
    "react-native",
    "cross-platform",
    "desktop",
    "khoj"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/prashmaybe/khoj/issues"
  },
  "homepage": "https://github.com/prashmaybe/khoj#readme",
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "crypto-js": "^4.2.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-native": "^0.85.3",
    "react-native-web": "^0.21.2",
    "react-native-webview": "^13.2.2",
    "react-webview": "^0.1.0",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@eslint/js": "^10.0.1",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.72.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "electron": "^42.0.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "metro": "^0.76.0",
    "metro-react-native-babel-preset": "^0.76.0",
    "rimraf": "^5.0.0",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.59.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "build": {
    "appId": "com.khoj.browser",
    "productName": "Khoj",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "src",
        "to": "src",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Khoj"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Khoj",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "compression": "maximum",
    "removePackageScripts": true
  }
}
