{
  "name": "khoj",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "web": "webpack serve --mode development",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run web\" \"wait-on http://localhost:8080 && electron .",
    "desktop": "npm run electron-dev",
    "build-web": "webpack --mode production",
    "build-electron": "npm run build-web && electron-builder",
    "test": "jest",
    "build": "npm run build-all",
    "build-all": "npm run build-web && npm run build-desktop && npm run build-mobile",
    "build-desktop": "npm run build-windows && npm run build-macos && npm run build-linux",
    "build-windows": "npm run build-web && electron-builder --win",
    "build-macos": "npm run build-web && electron-builder --mac",
    "build-linux": "npm run build-web && electron-builder --linux",
    "build-mobile": "npm run build-android && npm run build-ios",
    "build-android": "cd android && ./gradlew assembleRelease",
    "build-ios": "cd ios && xcodebuild -workspace Khoj.xcworkspace -scheme Khoj -configuration Release -destination generic/platform=iOS -archivePath build/Khoj.xcarchive archive",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist": "npm run build-web && electron-builder --publish=never",
    "dist-all": "npm run build-web && electron-builder -mwl --publish=never",
    "clean": "rimraf dist out build release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prashmaybe/khoj.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/prashmaybe/khoj/issues"
  },
  "homepage": "https://github.com/prashmaybe/khoj#readme",
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-native": "^0.72.0",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.4",
    "electron": "^42.0.0",
    "html-webpack-plugin": "^5.6.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native": "^0.72.0",
    "react-native-web": "^0.19.6",
    "react-native-webview": "^13.2.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "wait-on": "^9.0.5",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@react-native/metro-config": "^0.72.0",
    "electron-builder": "^24.0.0",
    "electron-packager": "^17.1.1",
    "metro": "^0.76.0",
    "metro-react-native-babel-preset": "^0.76.0",
    "rimraf": "^5.0.0"
  },
  "build": {
    "appId": "com.khoj.browser",
    "productName": "Khoj Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Khoj Browser"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "web": {
      "fingerprint": "null"
    }
  }
}
